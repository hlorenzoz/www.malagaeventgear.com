{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "$lib/*": ["../../src/lib/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../../src/lib/server/**/*.ts",
    "../../worker-configuration.d.ts",
    "../../src/app.d.ts"
  ],
  "exclude": [
    "node_modules",
    "../../src/lib/server/**/*.test.ts"
  ]
}
