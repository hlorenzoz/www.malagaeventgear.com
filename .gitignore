# ==============================================================================
# Malaga Event Gear (malagaeventgear.com) - Optimized .gitignore
# Stack: SvelteKit 2 + Svelte 5 + Bun + Vite + Cloudflare Pages & Wrangler
# ==============================================================================

# ------------------------------------------------------------------------------
# Dependencies & Package Managers
# ------------------------------------------------------------------------------
node_modules/
/package-lock.json
/yarn.lock
/pnpm-lock.yaml
# We use bun (bun.lock is tracked, but let's ignore Bun's debug/temp files)
bun-debug.log*

# ------------------------------------------------------------------------------
# Build & Output
# ------------------------------------------------------------------------------
.svelte-kit/
/build/
/dist/
/.output/
/package/

# Generated exports & local temporary media
*-export.ts

# Local image authoring source files — re-uploadable; refs + metadata are persisted in
# scripts/migrate-wp/manifest.json (tracked). assets/_urls.txt and meta.yaml are local scratch/input.
assets/

# ------------------------------------------------------------------------------
# Cloudflare / Wrangler & D1 Local State
# ------------------------------------------------------------------------------
.wrangler/
.dev.vars
# Cloudflare local D1 SQLite databases & journals
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ------------------------------------------------------------------------------
# Environment Variables & Secrets (CRITICAL SECURITY)
# ------------------------------------------------------------------------------
.env
.env.local
.env.[a-zA-Z]*
# Prevent ignoring the explicit template and testing environment configurations
!.env.example
!.env.test

# ------------------------------------------------------------------------------
# AI Agents & Local Skills
# ------------------------------------------------------------------------------
# Ignore locally downloaded or symlinked agent skills (re-creatable via skills-lock.json)
.agents/skills/

# ------------------------------------------------------------------------------
# IDEs, Editors & System Files
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# VS Code (except extensions)
.vscode/*
!.vscode/extensions.json

# JetBrains (WebStorm, PhpStorm, etc.)
.idea/

# Editors & Temporary files
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~
# Vite config timestamp files (hot module replacement / build artifacts)
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ------------------------------------------------------------------------------
# Logs & Diagnostic Reports
# ------------------------------------------------------------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
/test-results/

# ------------------------------------------------------------------------------
# Lighthouse Reports
# ------------------------------------------------------------------------------
/lighthouse-report.json
/lighthouse-report.html
.lighthouse/
.lighthouseci/

