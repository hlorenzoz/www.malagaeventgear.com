# Cloudflare Workers Assets headers

# Security headers for ALL static-asset + prerendered responses (blog posts,
# package pages, JS/CSS/images). SSR pages and /api/* are generated by the Worker
# and do NOT pass through this file — those get the SAME headers set in
# src/hooks.server.ts. Keep both in sync.
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()

# Fuentes self-hosted: nombre de archivo estable + contenido fijo → cache inmutable de 1 año.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
